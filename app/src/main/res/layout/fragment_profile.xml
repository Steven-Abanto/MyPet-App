<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CCF5FF"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/milkshake"
        android:padding="20dp"
        android:text="Perfil"
        android:textAlignment="center"
        android:textColor="#8BC34A"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clProfileInfo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="35dp"
        app:layout_constraintTop_toBottomOf="@id/tvContent"
        app:layout_constraintBottom_toTopOf="@id/btnLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/profilePicContainer"
            android:layout_width="150dp"
            android:layout_height="150dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/noprofilepic"
                android:scaleType="centerCrop" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfilePic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                app:shapeAppearanceOverlay="@style/CircleImageStyle" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/llProfileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="15dp"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toEndOf="@id/profilePicContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvProfileNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="Nombre del Usuario"
                android:textSize="20sp"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/llProfileLastname"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="15dp"
            android:layout_marginStart="10dp"
            app:layout_constraintTop_toBottomOf="@id/llProfileName"
            app:layout_constraintStart_toEndOf="@id/profilePicContainer"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/tvProfileLastname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@id/ivProfilePic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProfileNameText"
                android:text="Apellidos"
                android:textStyle="bold"
                />

            <TextView
                android:id="@+id/tvProfileLastnameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                app:layout_constraintStart_toEndOf="@id/ivProfilePic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProfileLastname"
                android:text="Apellidos del Usuari"
                android:textSize="20sp"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/llProfileBirthdateGender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="15dp"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@+id/profilePicContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:paddingEnd="5dp"
                android:layout_weight="2"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvProfileBirthdate"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Fecha de nacimiento"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvProfileBirthdateText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:text="01/01/1999"
                    android:textSize="20sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvProfileGender"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Pronombre"
                    android:textStyle="bold"
                    />

                <TextView
                    android:id="@+id/tvProfileGenderText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:text="Él/Ella/Otro"
                    android:textSize="20sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llProfileEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginVertical="15dp"
            app:layout_constraintTop_toBottomOf="@id/llProfileBirthdateGender"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email de contacto"
                android:textStyle="bold"
                />

            <TextView
                android:id="@+id/tvProfileEmailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="correo.contacto@mail.com"
                android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llProfilePhone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginVertical="15dp"
            app:layout_constraintTop_toBottomOf="@id/llProfileEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:id="@+id/tvProfilePhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono de contacto"
                android:textStyle="bold"
                />

            <TextView
                android:id="@+id/tvProfilePhoneText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:text="Teléfono de contacto"
                android:textSize="20sp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProfileEdit"
            app:icon="@drawable/ic_edit"
            android:layout_marginVertical="15dp"
            android:text="Editar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#8BC34A"
            app:layout_constraintTop_toBottomOf="@id/llProfilePhone">

        </com.google.android.material.button.MaterialButton>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProfilePasswordEdit"
            app:icon="@drawable/ic_edit"
            android:layout_marginVertical="15dp"
            android:text="Cambiar contraseña"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#A9A9A9"
            app:layout_constraintTop_toBottomOf="@id/btnProfileEdit">
        </com.google.android.material.button.MaterialButton>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="35dp"
        android:layout_marginVertical="15dp"
        android:text="Cerrar Sesión"
        android:backgroundTint="#FA4C4C"
        app:icon="@drawable/ic_edit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>